# LLM API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=

# Default model: "gemini" or "openai"
DEFAULT_MODEL=gemini

# Chunking settings
CHUNK_MAX_TOKENS=50000
CHUNK_OVERLAP_TOKENS=500

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_CAPTURE_IO=false

# Apify (social-media crawl) — required for "Explore Social Intent"
APIFY_TOKEN=

# Optional LLM / gap-analysis overrides (code defaults shown)
# GEMINI_MODEL=gemini-2.5-flash
# EMBEDDING_MODEL=models/gemini-embedding-001
# MATCH_HIGH=0.85
# MATCH_LOW=0.55
