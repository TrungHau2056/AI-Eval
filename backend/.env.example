# LLM API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
# Default model: "gemini" or "openai"
DEFAULT_MODEL=openai
OPENAI_MODEL=gpt-4o

# Chunking settings
CHUNK_MAX_TOKENS=50000
CHUNK_OVERLAP_TOKENS=500

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_CAPTURE_IO=false

# Apify (social-media crawl)
APIFY_TOKEN=

# Optional OpenAI per-call cost estimation.
# Values are USD per 1M tokens. Keep this catalog updated from the official pricing page.
# Single-line JSON is preferred; multiline JSON blocks are also supported by the backend cost logger.
# Replace the 0 placeholders with official rates; zero/missing rates are logged as price_missing.
# OPENAI_PRICING_JSON={"gpt-4o":{"input_per_1m":0,"output_per_1m":0,"source_url":"https://platform.openai.com/docs/pricing","checked_at":"YYYY-MM-DD"}}

OPENAI_PRICING_JSON={"gpt-4o":{"input_per_1m":2.5,"output_per_1m":10,"source_url":"https://platform.openai.com/docs/pricing","checked_at":"2026-06-30"}}