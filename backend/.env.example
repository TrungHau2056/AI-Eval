# LLM API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
# Default model: "gemini" or "openai"
DEFAULT_MODEL=openai

# Chunking settings
CHUNK_MAX_TOKENS=50000
CHUNK_OVERLAP_TOKENS=500

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_CAPTURE_IO=false

# Apify (social-media crawl)
APIFY_TOKEN=
