# LLM API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
# Default model: "gemini" or "openai"
DEFAULT_MODEL=openai
OPENAI_MODEL=gpt-4o-mini

# Optional OpenAI per-call cost estimation.
# Values are USD per 1M tokens. Keep this catalog updated from the official pricing page.
OPENAI_PRICING_JSON={}

# Chunking settings
CHUNK_MAX_TOKENS=50000
CHUNK_OVERLAP_TOKENS=500

# Persona generation loop
PERSONA_MAX_ITERATIONS=2
PERSONA_PASS_THRESHOLD=0.75

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_CAPTURE_IO=false

# Apify (social-media crawl)
APIFY_TOKEN=
